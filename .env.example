# ============================================================
# n8n 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を設定してください
# .env はリポジトリに含めないこと（.gitignore で除外済み）
# ============================================================

# n8n 基本設定
N8N_PROTOCOL=https
N8N_HOST=your-cloud-run-url.a.run.app
WEBHOOK_URL=https://your-cloud-run-url.a.run.app
N8N_ENCRYPTION_KEY=your-random-32char-encryption-key-here
N8N_BASIC_AUTH_ACTIVE=false

# 実行履歴の自動削除（7日）
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168

# ============================================================
# データベース（Neon Serverless PostgreSQL）
# https://console.neon.tech でプロジェクトを作成後に設定
# ============================================================
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=ep-xxxx-xxxxxx.ap-southeast-1.aws.neon.tech
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8ndb
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=your-neon-db-password
DB_POSTGRESDB_SSL=true

# ============================================================
# 外部サービス
# ============================================================

# Gemini API（https://aistudio.google.com/app/apikey）
GEMINI_API_KEY=your-gemini-api-key

# GAS WebApp URL（gas/pdf-extractor をデプロイ後に発行される URL）
GAS_WEBAPP_URL=https://script.google.com/macros/s/xxxx/exec

# 完了通知先メールアドレス
NOTIFY_EMAIL=your-email@example.com

# ============================================================
# n8n ワークフロー内 Variables（n8n UI の Settings > Variables で設定）
# Cloud Run 上ではシークレット経由で渡されるため .env への記載不要だが、
# ローカル開発時の参考として記載
# ============================================================
# DRIVE_INBOX_FOLDER_ID=your-google-drive-folder-id
# DRIVE_PROCESSING_FOLDER_ID=your-google-drive-folder-id
# DRIVE_REVIEWED_FOLDER_ID=your-google-drive-folder-id
# DRIVE_RESULTS_FOLDER_ID=your-google-drive-folder-id
# SHEETS_LOG_ID=your-google-sheets-spreadsheet-id
